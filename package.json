{
  "name": "vidpeek",
  "version": "1.0.0",
  "description": "Typed video preview generation for Node.js and CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vidpeek": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postigodev/vidpeek.git"
  },
  "bugs": {
    "url": "https://github.com/postigodev/vidpeek/issues"
  },
  "homepage": "https://github.com/postigodev/vidpeek#readme",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "bench": "tsx benchmarks/run.ts",
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run",
    "release:check": "pnpm typecheck && pnpm test && pnpm build && npm pack --dry-run",
    "smoke:consumer": "tsx scripts/smoke-consumer.ts"
  },
  "keywords": [
    "ffmpeg",
    "ffprobe",
    "video",
    "preview",
    "thumbnail",
    "webp",
    "cli",
    "typescript",
    "media",
    "node"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
