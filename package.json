{
  "name": "@postigodev/vidpeek",
  "version": "0.1.0",
  "description": "A modern typed FFmpeg preview generator for Node and CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vidpeek": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/postigodev/vidpeek.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "bench": "tsx benchmarks/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ffmpeg",
    "video",
    "preview",
    "webp",
    "gif",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "tsx": "^4.16.5",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
